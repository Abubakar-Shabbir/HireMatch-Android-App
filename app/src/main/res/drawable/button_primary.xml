<?xml version="1.0" encoding="utf-8"?>

<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Pressed -->
    <item android:state_pressed="true">
        <shape>
            <gradient
                android:angle="45"
                android:startColor="#111827"
                android:endColor="#1F2937" />

            <corners android:radius="18dp" />

            <stroke
                android:width="1dp"
                android:color="#8B5E3C" />
        </shape>
    </item>

    <!-- Normal -->
    <item>
        <shape>
            <gradient
                android:angle="45"
                android:startColor="#1F2937"
                android:endColor="#374151" />

            <corners android:radius="18dp" />

            <stroke
                android:width="1dp"
                android:color="#8B5E3C" />
        </shape>
    </item>

</selector>