<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    ```
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HireMatch"
            android:textStyle="bold"
            android:textSize="30sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome Candidate 👋"
            android:textSize="18sp"
            android:layout_marginBottom="25dp"/>

        <Button
            android:id="@+id/btnProfile"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="👤 My Profile"/>

        <Button
            android:id="@+id/btnResume"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="📄 Upload Resume"
            android:layout_marginTop="10dp"/>

        <Button
            android:id="@+id/btnATS"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="📊 ATS Score"
            android:layout_marginTop="10dp"/>

        <Button
            android:id="@+id/btnJobs"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="💼 Browse Jobs"
            android:layout_marginTop="10dp"/>
        <Button
            android:id="@+id/btnMyApplications"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="📂 My Applications"
            android:layout_marginTop="10dp"/>
        <Button
            android:id="@+id/btnNotifications"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="🔔 Notifications"
            android:layout_marginTop="10dp"/>

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="🚪 Logout"
            android:layout_marginTop="25dp"/>

    </LinearLayout>
    ```

</ScrollView>
