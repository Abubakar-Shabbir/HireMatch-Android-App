<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ================= Header ================= -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/primary"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/hirematch_logo" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HireMatch"
                    android:textColor="@android:color/white"
                    android:textSize="22sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Find your dream career"
                    android:textColor="#E8EAF6"
                    android:textSize="13sp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- ================= Title ================= -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginTop="18dp"
            android:layout_marginEnd="18dp"
            android:text="Browse Jobs"
            android:textColor="@color/text_primary"
            android:textSize="26sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="18dp"
            android:text="Search and explore available opportunities."
            android:textColor="@color/text_secondary"
            android:textSize="14sp"/>

        <!-- ================= Search Card ================= -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:background="@drawable/card_bg"
            android:elevation="3dp"
            android:orientation="vertical"
            android:padding="18dp">

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/input_bg"
                android:hint="Search by Job Title"
                android:padding="15dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"/>

            <EditText
                android:id="@+id/etLocationFilter"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/input_bg"
                android:hint="Filter by Location"
                android:padding="15dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"/>

        </LinearLayout>

        <!-- ================= Jobs Count ================= -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginBottom="8dp"
            android:text="Available Jobs"
            android:textColor="@color/primary"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <!-- ================= Recycler ================= -->

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvJobs"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="12dp"/>

    </LinearLayout>

</RelativeLayout>