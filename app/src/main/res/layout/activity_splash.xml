<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Background Layer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F8F4EF" />

    <!-- Logo -->
    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="150dp"
        android:scaleType="fitCenter"
        android:src="@drawable/hirematch_logo" />

    <!-- App Name -->
    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/imgLogo"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="18dp"
        android:text="HireMatch"
        android:textColor="@color/primary"
        android:textSize="38sp"
        android:textStyle="bold" />

    <!-- Divider -->
    <View
        android:id="@+id/dividerLine"
        android:layout_width="45dp"
        android:layout_height="2dp"
        android:layout_below="@id/tvAppName"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="14dp"
        android:background="@color/accent" />

    <!-- Tagline -->
    <TextView
        android:id="@+id/tvTagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/dividerLine"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="16dp"
        android:text="Smart Recruitment.\nBetter Connections."
        android:textAlignment="center"
        android:textColor="@color/text_secondary"
        android:textSize="15sp" />

    <!-- City Background -->
    <ImageView
        android:id="@+id/imgCity"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:layout_above="@id/bottomSection"
        android:adjustViewBounds="true"
        android:alpha="0.22"
        android:scaleType="fitXY"
        android:src="@drawable/city_bg" />

    <!-- Bottom Section -->
    <LinearLayout
        android:id="@+id/bottomSection"
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:layout_alignParentBottom="true"
        android:background="@drawable/splash_bottom_curve"
        android:gravity="center"
        android:orientation="vertical">

        <!-- Brand Icon -->
        <ImageView
            android:id="@+id/imgBriefcase"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/hirematch_logo"
            android:scaleType="fitCenter" />

        <!-- Loading Text -->
        <TextView
            android:id="@+id/tvLoading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Loading opportunities..."
            android:textColor="@color/white"
            android:textSize="16sp" />

        <!-- Progress Loader (Replaced broken Lottie) -->
        <ProgressBar
            android:id="@+id/loadingProgress"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginTop="18dp" />

    </LinearLayout>

</RelativeLayout>